{
  "$schema": "https://repomix.com/schemas/latest/schema.json",

  "output": {
    "filePath": "docs/repomix/docs.xml",
    "style": "xml",
    "parsableStyle": true,

    "removeComments": true,
    "removeEmptyLines": true,
    "truncateBase64": true,

    "fileSummary": false,
    "directoryStructure": true,
    "files": true,

    "showLineNumbers": true,

    "includeEmptyDirectories": false,
    "instructionFilePath": "docs/repomix/repomix-instruction.md",
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 20,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 1
    }
  },

  "include": [
    "api/**/*",
    "frontend/**/*",
    "sidequest/**/*",
    "scripts/**/*",
    "config/**/*",
    "cloudflare-workers/**/*",
    ".ast-grep/**/*",
    ".github/workflows/**/*",
    "*.json",
    "*.ts",
    "*.tsx",
    "*.js",
    "*.py",
    "*.sh"
  ],

  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,

    "customPatterns": [
      "docs/**",
      "docs/archive/**",
      "docs/backlog/**",
      "docs/repomix/**",

      "**/node_modules/**",
      "**/.next/**",
      "**/.turbo/**",
      "**/.vite/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",

      "**/.ast-grep-backups/**",

      "**/*.log",
      "**/*.tmp",
      "**/*.cache",
      "**/*.map",
      "**/*.min.js",
      "**/*.min.css",

      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.gif",
      "**/*.webp",
      "**/*.ico",
      "**/*.pdf",
      "**/*.zip",
      "**/*.tar",
      "**/*.gz",
      "**/*.tgz",
      "**/*.7z",

      "**/*.mp4",
      "**/*.mov",
      "**/*.avi",
      "**/*.mp3",
      "**/*.wav",

      "**/.env",
      "**/.env.*",
      "**/*.pem",
      "**/*.key",
      "**/*.p12",
      "**/*.pfx"
    ]
  },


  "security": {
    "enableSecurityCheck": true
  },

  "tokenCount": {
    "encoding": "o200k_base"
  },
}