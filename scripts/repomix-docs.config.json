{
  "$schema": "https://repomix.com/schemas/latest/schema.json",

  "output": {
    "style": "xml",
    "parsableStyle": true,
    "removeComments": true,
    "removeEmptyLines": true,
    "truncateBase64": true,
    "fileSummary": false,
    "directoryStructure": true,
    "files": true,
    "showLineNumbers": false,
    "includeEmptyDirectories": false,
    "git": {
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 1
    }
  },

  "include": [
    "docs/**"
  ],

  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "docs/repomix/repomix-docs.xml",
      "**/node_modules/**"
    ]
  },

  "security": {
    "enableSecurityCheck": true
  },

  "tokenCount": {
    "encoding": "o200k_base"
  }
}
