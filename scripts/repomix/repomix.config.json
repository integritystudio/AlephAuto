{
  "$schema": "https://repomix.com/schemas/latest/schema.json",

  "input": {
    "maxFileSize": 50000000
  },

  "output": {
    "filePath": "docs/repomix/repo-compressed.xml",
    "style": "xml",
    "parsableStyle": true,

    "compress": true,
    "removeComments": true,
    "removeEmptyLines": true,
    "truncateBase64": true,

    "fileSummary": false,
    "directoryStructure": true,
    "files": true,

    "topFilesLength": 20,
    "showLineNumbers": false,
    "copyToClipboard": false,

    "includeEmptyDirectories": false,
    "includeFullDirectoryStructure": true,

    "headerText": "Repo bundle generated by Repomix (XML output, compressed). Focus on core runtime code first: api/, sidequest/, frontend/, scripts/, config/. Docs are mostly excluded to control token bloat. Git diffs/logs are disabled.",

    "instructionFilePath": "docs/repomix/repomix-instruction.md",

    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 200,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 1
    }
  },

  "include": [
    "api/**/*",
    "frontend/**/*",
    "sidequest/**/*",
    "cloudflare-workers/**/*",
    "config/**/*",
    "scripts/**/*",
    "nginx/**/*",
    ".github/**/*",
    ".husky/**/*",
    ".ast-grep/**/*",

    "package.json",
    "pnpm-workspace.yaml",
    "tsconfig.json",
    "eslint.config.js",
    "render.yaml",
    "requirements.txt",
    "README.md",
    "CLAUDE.md",
    "GEMINI.md",
    ".mise.toml",
    ".repomixignore",
    ".env.example"
  ],

  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,

    "customPatterns": [
      "**/docs/**",
      "docs/**",

      "docs/repomix/**",
      "**/repomix-output.*",
      "**/repo-compressed.*",
      "**/repo-compressed.xml",
      "**/repomix.xml",

      "**/.ast-grep-backups/**",
      ".ast-grep-backups/**",

      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/out/**",
      "**/.next/**",
      "**/.turbo/**",
      "**/.vite/**",
      "**/coverage/**",

      "**/*.log",
      "**/*.tmp",
      "**/*.temp",
      "**/*.cache",
      "**/*.swp",
      "**/*.swo",
      "**/*.tsbuildinfo",
      "**/*.map",
      "**/*.min.js",
      "**/*.min.css",

      "**/__snapshots__/**",
      "**/*.snap",
      "tests/**",
      "**/*.test.*",
      "**/*.spec.*",

      "**/fixtures/**",
      "**/test-files/**",
      "**/manual/**",
      "**/results/**",

      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.gif",
      "**/*.webp",
      "**/*.ico",
      "**/*.pdf",
      "**/*.zip",
      "**/*.tar",
      "**/*.gz",
      "**/*.tgz",
      "**/*.7z",
      "**/*.mp4",
      "**/*.mov",
      "**/*.avi",
      "**/*.mp3",
      "**/*.wav",

      "**/.env",
      "**/.env.*",
      "**/*.pem",
      "**/*.key",
      "**/*.p12",
      "**/*.pfx",
      "**/*secret*"
    ]
  },

  "security": {
    "enableSecurityCheck": true
  },

  "tokenCount": {
    "encoding": "o200k_base"
  },

  "tokenBudget": {
    "maxTokens": 200000
  }
}
