// Code 2
if (user.role !== 'admin') { /* ... */ }

// Features Extracted:
// features1.logical_operators = {'==='}
// features2.logical_operators = {'!=='}

// After normalization (identical!):
if(var.var === 'STR'){/* ... */}  # Note: === preserved

// Base similarity = 0.85 (Levenshtein)
// Penalty = 0.80 (operator mismatch)
