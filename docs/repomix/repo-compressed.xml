FORCE_COLOR=0 NO_COLOR=1 npx repomix "$ROOT" --token-count-tree --no-files --no-file-summary 2>&1 \
  | tr -d '\r' \
  | sed -E 's/\x1B\[[0-9;]*[A-Za-z]//g' \
  | awk 'BEGIN{keep=0} /^🔢 Token Count Tree:/{keep=1} /^🔎 Security Check:/{keep=0} keep' \
  > "$OUTPUT_FILE"
</file>

