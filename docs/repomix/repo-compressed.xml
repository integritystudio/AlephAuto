    CREATE_UTILITY = "create_utility"           # Utility function
    PARAMETERIZE = "parameterize"               # Add parameters to unify
    TEMPLATE = "template"                       # Use template pattern


class Priority(str, Enum):
    """Priority level for addressing suggestion"""
