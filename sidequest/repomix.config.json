{
  "$schema": "https://repomix.com/schemas/latest/schema.json",

  "output": {
    "style": "xml",
    "parsableStyle": true,

    "compress": false,
    "removeComments": true,
    "removeEmptyLines": true,
    "truncateBase64": true,

    "directoryStructure": true,
    "files": true,
    "fileSummary": false,

    "topFilesLength": 10,
    "showLineNumbers": false,

    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 200,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 1
    }
  },

  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "docs/repomix/**",
      "**/repomix-output.*",
      "**/repo-compressed.*",
      "**/repomix.xml",
      "**/repo-compressed.xml",
      "**/docs/**",
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/out/**",
      "**/.next/**",
      "**/.turbo/**",
      "**/.vite/**",
      "**/coverage/**",
      "**/fixtures/**",
      "**/test-files/**",
      "**/__snapshots__/**",
      "**/*.snap",
      "tests/**",
      "**/*.test.*",
      "**/*.spec.*",
      "**/*.log",
      "**/*.tmp",
      "**/*.temp",
      "**/*.cache",
      "**/*.swp",
      "**/*.swo",
      "**/*.tsbuildinfo",
      "**/__pycache__/**",
      "**/*.pyc",
      "**/*.pyo",
      "**/*.map",
      "**/*.min.js",
      "**/*.min.css",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.gif",
      "**/*.webp",
      "**/*.ico",
      "**/*.pdf",
      "**/*.zip",
      "**/*.tar",
      "**/*.gz",
      "**/*.tgz",
      "**/*.7z",
      "**/*.mp4",
      "**/*.mov",
      "**/*.avi",
      "**/*.mp3",
      "**/*.wav",
      "**/.env",
      "**/.env.*",
      "**/*.pem",
      "**/*.key",
      "**/*.p12",
      "**/*.pfx",
      "**/*secret*",
      ".claude/**",
      "**/.claude/**",
      ".ast-grep-backups/**",
      "**/.ast-grep-backups/**"
    ]
  },

  "security": {
    "enableSecurityCheck": false
  },

  "tokenCount": {
    "encoding": "o200k_base"
  }
}
