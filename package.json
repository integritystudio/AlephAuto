{
  "name": "repomix-cron-sidequest",
  "version": "1.0.0",
  "description": "Automated job management with sidequest server - repomix runner and documentation enhancement pipeline",
  "main": "api/server.ts",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node --strip-types api/server.ts",
    "start:api": "node --strip-types api/server.ts",
    "dev": "node --strip-types --watch api/server.ts",
    "build:frontend": "cd frontend && npm ci --include=dev && npm run build",
    "dashboard": "doppler run -- node --strip-types api/server.ts",
    "fix:types": "node --strip-types scripts/setup/fix-types.ts",
    "test": "node --strip-types --test --test-timeout=30000 --test-force-exit --test-name-pattern='.' tests/unit/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=text-summary node --strip-types --test --test-timeout=30000 --test-force-exit --test-name-pattern='.' tests/unit/*.test.ts",
    "test:coverage:html": "c8 --reporter=html --reporter=text-summary node --strip-types --test --test-timeout=30000 --test-force-exit --test-name-pattern='.' tests/unit/*.test.ts",
    "test:integration": "node --strip-types --test --test-timeout=60000 --test-force-exit --test-concurrency=1 tests/integration/*.test.ts",
    "test:cache": "node --strip-types --test --test-timeout=60000 --test-force-exit tests/integration/test-cache-layer.ts",
    "test:all:core": "SKIP_ENV_SENSITIVE_TESTS=1 node --strip-types --test --test-timeout=30000 --test-force-exit $(rg --files tests/unit -g '*.test.ts' -g '!api-routes.test.ts') $(rg --files tests/integration -g '*.test.ts' -g '!error-recovery.integration.test.ts' -g '!pipeline-execution.integration.test.ts' -g '!port-manager.integration.test.ts') sidequest/core/*.test.ts sidequest/pipeline-runners/*.test.ts sidequest/utils/*.test.ts sidequest/workers/*.test.ts",
    "test:all:env-safe": "echo 'No env-safe tests currently defined'",
    "test:all:env-host-required": "node --strip-types --test --test-timeout=60000 --test-force-exit tests/unit/api-routes.test.ts tests/unit/port-manager.test.ts tests/unit/websocket.test.ts tests/integration/error-recovery.integration.test.ts tests/integration/pipeline-execution.integration.test.ts tests/integration/port-manager.integration.test.ts sidequest/pipeline-runners/startup-once-mode.test.ts",
    "test:all:env": "npm run test:all:env-safe && npm run test:all:env-host-required",
    "test:all:node": "npm run test:all:core",
    "test:all:py": "bash scripts/analysis/run-python-tests.sh",
    "test:all": "npm run test:all:core && npm run test:all:py",
    "test:all:full": "npm run test:all:core && npm run test:all:env && npm run test:all:py",
    "test:aall": "npm run test:all",
    "test:validate-paths": "node --strip-types tests/scripts/validate-test-paths.ts",
    "test:validate-backlog": "node --strip-types tests/scripts/validate-backlog.ts",
    "test:single": "node --strip-types tests/scripts/test-single-job.ts",
    "test:scanner": "node --strip-types tests/scripts/test-directory-scanner.ts",
    "test:gitignore": "node --strip-types tests/scripts/test-gitignore-respect.ts",
    "test:repomix-fix": "node --strip-types tests/scripts/test-repomix-fix.ts",
    "docs:enhance": "RUN_ON_STARTUP=true doppler run -- node --strip-types sidequest/pipeline-runners/schema-enhancement-pipeline.ts",
    "docs:enhance:dry": "RUN_ON_STARTUP=true doppler run -- node --strip-types sidequest/pipeline-runners/schema-enhancement-pipeline.ts --dry-run",
    "docs:enhance:schedule": "doppler run -- node --strip-types sidequest/pipeline-runners/schema-enhancement-pipeline.ts",
    "docs:test": "node --strip-types sidequest/pipeline-runners/schema-enhancement-pipeline.ts --run --dry-run --dir .",
    "constants:generate:http-status": "node --strip-types scripts/codegen/generate-http-status-constants.ts",
    "git:weekly": "node --strip-types sidequest/pipeline-runners/git-activity-pipeline.ts --weekly",
    "git:monthly": "node --strip-types sidequest/pipeline-runners/git-activity-pipeline.ts --monthly",
    "git:schedule": "node --strip-types sidequest/pipeline-runners/git-activity-pipeline.ts",
    "plugin:audit": "RUN_ON_STARTUP=true node --strip-types sidequest/pipeline-runners/plugin-management-pipeline.ts",
    "plugin:audit:detailed": "DETAILED=true RUN_ON_STARTUP=true node --strip-types sidequest/pipeline-runners/plugin-management-pipeline.ts",
    "plugin:schedule": "node --strip-types sidequest/pipeline-runners/plugin-management-pipeline.ts",
    "claude:health": "zsh -c 'source ~/.zshrc && RUN_ON_STARTUP=true node --strip-types sidequest/pipeline-runners/claude-health-pipeline.ts'",
    "claude:health:detailed": "zsh -c 'source ~/.zshrc && DETAILED=true RUN_ON_STARTUP=true node --strip-types sidequest/pipeline-runners/claude-health-pipeline.ts'",
    "claude:health:schedule": "zsh -c 'source ~/.zshrc && node --strip-types sidequest/pipeline-runners/claude-health-pipeline.ts --cron'",
    "claude:health:quick": "zsh -c 'source ~/.zshrc && SKIP_PERFORMANCE=true SKIP_PLUGINS=true RUN_ON_STARTUP=true node --strip-types sidequest/pipeline-runners/claude-health-pipeline.ts'",
    "gitignore:update": "RUN_ON_STARTUP=true doppler run -- node --strip-types sidequest/pipeline-runners/gitignore-pipeline.ts",
    "gitignore:update:dry": "GITIGNORE_DRY_RUN=true RUN_ON_STARTUP=true doppler run -- node --strip-types sidequest/pipeline-runners/gitignore-pipeline.ts",
    "gitignore:schedule": "doppler run -- node --strip-types sidequest/pipeline-runners/gitignore-pipeline.ts",
    "cleanup:once": "RUN_ON_STARTUP=true doppler run -- node --strip-types sidequest/pipeline-runners/repo-cleanup-pipeline.ts",
    "cleanup:dryrun": "CLEANUP_DRY_RUN=true RUN_ON_STARTUP=true doppler run -- node --strip-types sidequest/pipeline-runners/repo-cleanup-pipeline.ts",
    "cleanup:schedule": "doppler run -- node --strip-types sidequest/pipeline-runners/repo-cleanup-pipeline.ts",
    "setup:sentry": "node docs/setup/setup-sentry.js",
    "verify": "node --strip-types scripts/setup/verify-setup.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "logs:cleanup": "node --strip-types scripts/logs/cleanup-error-logs.ts",
    "logs:cleanup:dry": "node --strip-types scripts/logs/cleanup-error-logs.ts --dry-run",
    "logs:cleanup:verbose": "node --strip-types scripts/logs/cleanup-error-logs.ts --verbose",
    "permissions:check": "node --strip-types scripts/setup/validate-permissions.ts --check-only",
    "permissions:fix": "node --strip-types scripts/setup/validate-permissions.ts --fix",
    "prestart": "node --strip-types scripts/setup/validate-permissions.ts --fix",
    "repomix": "bash scripts/repomix/repomix-regen.sh",
    "verify:bugfixes": "./scripts/deploy/verify-bugfixes.sh",
    "verify:bugfixes:pre": "./scripts/deploy/verify-bugfixes.sh --pre",
    "verify:bugfixes:post": "./scripts/deploy/verify-bugfixes.sh --post",
    "verify:bugfixes:health": "./scripts/deploy/verify-bugfixes.sh --health",
    "verify:bugfixes:smoke": "./scripts/deploy/verify-bugfixes.sh --smoke",
    "bugfix:once": "doppler run -- node --strip-types sidequest/pipeline-runners/bugfix-audit-pipeline.ts --run-now",
    "bugfix:schedule": "doppler run -- node --strip-types sidequest/pipeline-runners/bugfix-audit-pipeline.ts --recurring",
    "bugfix:tonight": "doppler run -- node --strip-types sidequest/pipeline-runners/bugfix-audit-pipeline.ts --once",
    "dashboard:populate": "RUN_ON_STARTUP=true node --strip-types sidequest/pipeline-runners/dashboard-populate-pipeline.ts --run-now",
    "dashboard:populate:full": "RUN_ON_STARTUP=true node --strip-types sidequest/pipeline-runners/dashboard-populate-pipeline.ts --run-now --no-seed",
    "dashboard:populate:dry": "RUN_ON_STARTUP=true node --strip-types sidequest/pipeline-runners/dashboard-populate-pipeline.ts --run-now --dry-run",
    "dashboard:populate:schedule": "node --strip-types sidequest/pipeline-runners/dashboard-populate-pipeline.ts"
  },
  "keywords": [
    "repomix",
    "cron",
    "sidequest",
    "sentry",
    "documentation",
    "schema.org",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@isaacs/brace-expansion": "^5.0.1",
    "@sentry/node": "^7.120.4",
    "@shared/logging": "workspace:*",
    "@shared/process-io": "workspace:*",
    "@types/pg": "^8.18.0",
    "cors": "^2.8.6",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jsdom": "^27.4.0",
    "marked": "^17.0.4",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "repomix": "^1.12.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@electric-sql/pglite": "^0.3.16",
    "@eslint/js": "^10",
    "@sentry/vite-plugin": "^4.9.1",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20.19.35",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "c8": "^10.1.3",
    "chai": "^4.5.0",
    "eslint": "^10.0.2",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-sonarjs": "^4.0.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "optionalDependencies": {
    "@ast-grep/cli": "^0.40.5"
  },
  "imports": {
    "#sidequest/*.ts": "./sidequest/*.ts",
    "#api/types/*.ts": "./api/types/*.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [],
    "overrides": {
      "qs": ">=6.14.1"
    },
    "ignoredBuiltDependencies": [
      "@sentry/cli"
    ]
  }
}
